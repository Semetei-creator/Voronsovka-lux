# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Stripe Integration Keys (optional, defaults to fully functional demo sandbox if not set)
# STRIPE_SECRET_KEY: Stripe service-side private key (sk_test_...)
STRIPE_SECRET_KEY=
# VITE_STRIPE_PUBLIC_KEY: Stripe browser-side key (pk_test_...)
VITE_STRIPE_PUBLIC_KEY=

# Resend Email Integration Key (optional, falls back to mock logger/simulator if not set)
RESEND_API_KEY=

# Telegram Integration Keys (optional, falls back to simulated notification log if not set)
# TELEGRAM_BOT_TOKEN: The token from @BotFather
TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID: The target user/group chat ID (e.g. 123456789 or @channelname)
TELEGRAM_CHAT_ID=

